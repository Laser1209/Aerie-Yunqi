# Aerie · 云栖 v0.1.0-beta.1 — Environment Variables Example
# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` to git (covered by .gitignore).

# ===== AI Providers (LLM) =====
# Primary: Qwen (DashScope, OpenAI-compatible)
DASHSCOPE_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Backup: DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Specialized: Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash-exp

# MiniMax (model company)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# BigModel / Zhipu GLM
BIGMODEL_API_KEY=your_bigmodel_api_key_here
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
BIGMODEL_MODEL=glm-4-plus

# SiliconFlow  (official: api.siliconflow.com, model google/gemma-4-26B-A4B-it)
# Available Gemma models on SiliconFlow:
#   - google/gemma-4-26B-A4B-it  (free, ~1.4s)
#   - google/gemma-4-31B-it      (paid, may be quota-limited)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_MODEL=google/gemma-4-26B-A4B-it

# OpenAI / GPT  (proxy: api.codexgood.com)
# Available models on this proxy (user-verified 2026-07-16):
#   - gpt-5.5           (validated PASS, 2.33s)
#   - gpt-5.6-luna
#   - gpt-5.6-sol
#   - gpt-5.6-terra
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.codexgood.com/v1
OPENAI_MODEL=gpt-5.5

# ===== Image Generation (gpt-image-2) =====  ← 预置，未来生图模式用
# 接口: POST {IMAGE_GEN_BASE_URL}/images/generations
# 请求头: Authorization: Bearer <key> / Idempotency-Key: <uuid>
# 并发上限: 2
IMAGE_GEN_API_KEY=your_image_gen_api_key_here
IMAGE_GEN_BASE_URL=https://image2.inian.one/v1
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_GEN_ENDPOINT=/images/generations
IMAGE_GEN_CONCURRENCY=2

# ===== QQ / NapCat =====
SELF_QQ=123456789

# Mobile gateway authentication (generate at least 32 random bytes; never commit the value)
AERIE_PRIMARY_USER_ID=
AERIE_MOBILE_TOKEN_PEPPER=
AERIE_MOBILE_AUTH_DB=data/mobile_gateway.db
# Production activation overrides; repository feature defaults remain off.
AERIE_FEATURE_IDENTITY_CONTRACT_V1=false
AERIE_FEATURE_CONVERSATION_MODEL_V1=false
AERIE_FEATURE_CHAT_REQUEST_QUEUE_V1=false
AERIE_FEATURE_MOBILE_GATEWAY_V1=false
FRIENDS_QQ=987654321,111222333
NAPCAT_WS_URL=ws://127.0.0.1:3001

# ===== HTTP API =====
HTTP_API_HOST=127.0.0.1
HTTP_API_PORT=7890

# ===== Logging =====
LOG_LEVEL=INFO
LOG_DIR=logs
