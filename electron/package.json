{
  "name": "aerie-companion",
  "productName": "Aerie · 云栖",
  "version": "0.1.0-beta.1",
  "description": "Aerie · 云栖 — Local-first AI companion with auto-wake proactive messenger / 本地优先 AI 桌面伴侣",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 && node scripts/post-build-rcedit.js",
    "build:win:alt": "electron-builder --win --x64 --config.directories.output=dist-final && node scripts/post-build-rcedit.js",
    "build:icons": "node scripts/build-icon-sprite.js",
    "check:emojis": "node scripts/check-emojis.js",
    "check:forbidden": "python ../tools/check_forbidden.py",
    "check:tokens": "python ../tools/check_tokens.py",
    "check:all": "npm run check:emojis && npm run check:forbidden && npm run check:tokens",
    "prebuild": "npm run check:emojis && npm run build:icons",
    "lint": "echo 'No JS lint configured'"
  },
  "author": "Laser",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "sharp": "^0.32.6"
  },
  "build": {
    "appId": "com.laser.aerie",
    "productName": "Aerie · 云栖",
    "copyright": "Copyright © 2026 Laser",
    "directories": {
      "output": "dist",
      "buildResources": "builder"
    },
    "files": [
      "src/**/*",
      "builder/icon.ico",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/{__pycache__,*.pyc,*.pyo,*.pyd,*.egg-info}",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{.idea,.vscode,.editorconfig,.travis.yml,.npmrc}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "asar": true,
    "asarUnpack": ["**/*.node"],
    "win": {
      "icon": "builder/icon.ico",
      "executableName": "Aerie 云栖",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "publisherName": "Laser",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "extraResources": [
      {
        "from": "../Aerie · 云栖.png",
        "to": "icon.png"
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      },
      {
        "from": "../",
        "to": "python",
        "filter": [
          "main.py",
          "core/**",
          "config/**",
          "communication/**",
          "knowledge/**",
          "memory/**",
          "emotion/**",
          "persona/**",
          "scheduler/**",
          "tools/__init__.py",
          "tools/browser_tools.py",
          "tools/douyin_tools.py",
          "tools/compute_tools.py",
          "tools/restart_helper.ps1",
          "skills/local/*/SKILL.md",
          "skills/local/*/run.py",
          "skills/data/*/SKILL.md",
          "skills/data/*/run.py",
          "douyin-mcp/src/douyin_creator_mcp/**",
          "NapCat/NapCat.Shell/**",
          ".env.example",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!data/**",
          "!logs/**",
          "!NapCat/NapCat.Shell/cache/**",
          "!NapCat/NapCat.Shell/config/**",
          "!douyin-mcp/data/**",
          "!douyin-mcp/.env"
        ]
      },
      {
        "from": "../.venv",
        "to": "python/.venv",
        "filter": [
          "**/*",
          "!Lib/site-packages/pip/**",
          "!Lib/site-packages/setuptools/**",
          "!Lib/site-packages/wheel/**",
          "!Scripts/pip*",
          "!Scripts/activate*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo"
        ]
      }
    ],
    "nsis": {
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aerie · 云栖",
      "deleteAppDataOnUninstall": false,
      "include": "builder/installer.nsh",
      "displayLanguageSelector": false,
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "extraMetadata": {
      "main": "src/main.js",
      "author": {
        "name": "Laser",
        "email": "laser@local"
      }
    },
    "publish": null
  }
}
